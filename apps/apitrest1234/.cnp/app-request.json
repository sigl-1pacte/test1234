      "provisioning": "grafana-operator",
      "teamSubspacePath": "/teams/valentin-team/observability/logs"
    },
    "labelSelector": "cnp.io/logging=enabled,project=apitrest1234,team=valentin-team",
    "logsEnabled": true,
    "requiredPodLabels": {
      "cnp.io/logging": "enabled",
      "project": "apitrest1234",
      "team": "valentin-team"
    }
  },
  "owner": "",
  "projectName": "apitrest1234",
  "projectSlug": "test1234",
  "repository": {
    "githubOrg": "sigl-1pacte",
    "private": false
  },
  "routing": {
    "reason": "No sensitive data declared; AWS EKS is the public managed cluster target.",
    "targetCluster": "aws-eks"
  },
  "security": {
    "containsSensitiveData": false,
    "dataClassification": "public",
    "publicExposure": true,
    "requiresSecrets": false
  },
  "teamName": "valentin-team",
  "template": {
    "appType": "python-api",
    "framework": "fastapi",
    "language": "python"
  }
