    "replicas": 1,
    "resources": {
      "requests": {
        "cpu": "500m",
        "memory": "512Mi"
      }
    },
    "servicePort": 8000,
    "tlsEnabled": false
  },
  "kind": "service",
  "observability": {
    "backend": "loki",
    "collector": "alloy",
    "grafana": {
      "datasource": "Loki",
      "folderName": "valentin-team-apitrest1234",
      "folderTitle": "valentin-team / apitrest1234",
