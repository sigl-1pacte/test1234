{
  "argocd": {
    "autoSync": true,
    "enabled": true,
    "prune": false,
    "repositoryTarget": "",
    "revision": "main",
    "selfHeal": true
  },
  "database": {},
  "description": "",
  "environments": [
    "dev"
  ],
  "features": {
    "ci": true,
    "envConfig": false,
    "logger": true,
    "yamlConfig": false
  },
  "helm": {
    "appPort": 8000,
    "config": {
      "logLevel": "INFO"
    },
    "enabled": true,
    "host": "apitrest1234.test1234.cnp.1pacte.tech",
